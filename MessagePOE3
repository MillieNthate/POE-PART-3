public class MessagejavaPOE3 {
    java package com.mycompany.chatapp1;
    
    import java.io.FileWriter; 
    import java.io.IOException;
    import java.util.Random;
    
    public class Message { 
        
        private static int totalMessagesSent =0;
        
        // Part 3 Arrays
        
        public static Message[] sentMessages = new Message[100]; 
        public static Message[] storedMessages = new Message[100]; 
        public static Message[] disregardMessages = new Message[100];
        
        public static String[] messageHashes = new String[100]; 
        public static String[] messageIDs = new String[100]; 
        
        private static int sentCount = 0;
        private static int storedCount = 0;
        private static int disregardCount = 0; 
        private static int hashCount = 0; 
        private static int idCount = 0;
        
        private String messageID;
        private int numSent; 
        private String recipient; 
        private String messageText;
        private String messageHash; 
        private String status; 
        
        public Meessage(String recipient, String messageText, int messageNumber) {
            this.recipient = recipient; 
            this.messageText = messageText; 
            this.numSent = messageNumber; 
            
            this.messageID = generateMessageID();
            this.messageHash = createMessageHash(messageNumber);
            
            status = "pending"; 
        }  
        public boolean checkMessageID() {
            return messageID.length() == 10; 
    }
        public String checkRecipientCell() { 
            Login loginValidator = new Login(); 
            if (loginValidator.checkCellPhoneNumber(recipient)) {
                return "Cell phone number successfully captured."; 
            }
            return "Cell phone number is incorrectly formatted or does not contain an international code. Please correct the number and try again.";
        }
        public String checkMessageLength() {
            if (messageText.length() <=250) {
                return "Message ready to send.";
            } 
            int excess = messageText.length() - 250; 
            return "Message excess 250 characters by " 
                    + excess 
                    + "; please reduce the size.";
        }
        public String createMessageHash(int messageNumber) { 
            String firstTwo = 
                    messageID.substring(0, 2);
            String[] words = 
                    messageText.trim().split("\\s+"); 
            String firstWord = 
                    words[0].replaceAll("[^a-zA-Z0-9]", "");
            String lastWord =
                    words[words.length - 1]
                    .replaceAll("[^a-zA-Z0-9]", ""); 
            String hash =
                    firstTwo
                    + ":"
                    + messageNumber 
                    + ":" 
                    + firstWord
                    + lastWord; 
            return hash.toUpperCase();
        } 
        public String sentMessage(int choice) {
            messageHashes[hashCount] = messageHash; 
            hashCount++; 
            messageIDs[idCount] = messageID;
            idCount++; 
            
            if (choice == 1) { 
                status = "sent";
                
                sentMessages[sentCount] = this; 
                sentCount++;
                
                totalMessagesSent++; 
                storeMessageInJSON();
                return "Message successfully sent.";
            } 
            else if (choice == 2) {
                status = "disregarded."; 
                disregardedMessages[disregardedCount] = this; 
                disregardedCount++; 
                return "Press 0 to delete the message.";
            } 
            else if (choice == 3) { 
                status = "stored"; 
                storedMessages[storedCount] = this;
                storedCount++;
                storeMessageInJSON(); 
                return "Message successfully stored.";
            } 
            return "Invalid option."; 
        } 
        // Display Stored Messages
        public static String displayStoredMessages() { 
            String result = ""; 
            for (int i = 0; i < storedCount; i++) {
                result += 
                        "Recipient: "
                        + storedMessages[i].recipient 
                        + "\nMessage: " 
                        + storedMessages[i].messageText 
                        + "\n\n";
            }
            return result; 
        }
        //LONGEST STORED MESSAGE
        public static String displayLongestMessage() { 
            if (storedCount == 0) { 
                return "No stored messages."; 
            }
            String longest = storedMessages[0].messageText;
            for (int i = 1; i < storedCount; i++) { 
                if (storedMessages[i]
                        .messageText.length()
                        > longest.length()) { 
                    longest = storedMessages[i].messageText; 
                }
            }
            return longest;
        }
        // SEARCH MESSAGE ID
        public static String searchMessageID(String id) { 
            for (int i = 0; i < sentCount; i++) {
                if (sentMessages[i]
                        .messageID.equals(id)) {
                    return "Recipient: "
                            + sentMessages[i].recipient 
                            + "\nMessage: "
                            + sentMessages[i].messageText;
                }
            }
            for (int i = 0; i < storedCount; i++) { 
                if (storedMessages[i].messageID.equals(id)) { 
                    return 
                            "Recipient: "
                            + storedMessages[i].recipient
                            + "\nMessage: "
                            + storedMessages[i].messageText;
                }
            } 
            return "Message not found.";
        }
        // SEARCH RECIPIENT
        public static String searchRecipient( 
        String recipientNumber) { 
            String result = ""; 
            for (int i = 0; i < sentCount; i++) { 
                if (sentMessages[i]
                        .recipient.equals(recipientNumber)) {
                    result += 
                            sentMessages[i]
                            . messageText
                            + "\n"; 
                }
            }
            for (int i = 0; i < storedCount; i++) {
                if (storedMessages[i]
                        .recipient.equals(recipientNumber)) { 
                    result += 
                            storedMessages[i]
                            .messageText
                            + "\n";
                }
            }
            return result;
        }
        // DELETE BY HASH
        public static String deleteByHash(String hash) { 
            for (int i = 0; i < storedCount; i++) { 
                if (storedMessages[i]
                        .messageHash.equals(hash)) { 
                    String deleted = 
                            storedMessages[i]
                            .messageText;
                    for (int j = i;
                            j < storedCount - 1;
                            j++) { 
                        storedMessages[j] = 
                                storedMessages[j + 1];
                    }
                    storedCount--;
                    return 
                            "Message: \""
                            + deleted 
                            + "\" successfully deleted.";
                }
            }
            return "Message not found.";
        }
        // REPORT 
        public static String displayReport() {
            String report = "";
            for (int i = 0; i < sentCount; i++) { 
                report += 
                        "Message hash: "
                        + sentMessages[i].messageHash 
                        + "|nRecipient: "
                        + sentMessages[i].recipient 
                        + "\nMessage: " 
                        + sentMessages[i].messageText 
                        + "\n\n";
            } 
            return report;
        } 
        private void storeMessageInJSON() {
            try { 
                FileWriter writer =
                        new FileWriter(
                        "messages.json",
                        true
                        ); 
                writer.write(
                "{"
                + "\"messageID\":\""
                + messageID 
                + "\"," 
                + "\recipient\":\"" 
                + recipient 
                + "\"," 
                + "\"hash\":\"" 
                + messageHash 
                + "\"," 
                + "\"status\":\""
                + status 
                + "\"" 
                + "}\n"
                ); 
            }
            catch (IOException e) { 
                System.out.println( 
                          "Error saving JSON file."
                );
            }
        }
        private String generateMessageID() {
           Random rand = new Random();
           long id = 
                   1000000000L 
                   + (long) 
                   (rand.nextDouble() 
                           * 9000000000L);
            return String.valueOf(id);
    } 
    public String getMessageID() {
            return messageID; 
    } 
    public String getMessageHash() {
            return messageHash; 
    } 
    public String getRecipient() {
            return recipient; 
    } 
    public String getMessageText() {
            return messageText;
    }
    public String getStatus() { 
            return status;
    } 
    public String getNumSent() {
            return numSent;
    }
    public int returnTotalMessages() {
            return totalMessagesSent;
    }
}
